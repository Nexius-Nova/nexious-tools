{
  "name": "nexious-tools",
  "version": "1.0.0",
  "description": "桌面端工具集 - 网站链接管理、密码管理、代码片段管理",
  "main": "electron/main.cjs",
  "author": "Nexious",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm run server\" \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "build:server": "node build-server.js",
    "server": "node server/index.js",
    "start": "electron-forge start",
    "prepackage": "npm run build && npm run build:server",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@vicons/ionicons5": "^0.13.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.18.3",
    "icon-extractor": "^1.0.3",
    "md-editor-v3": "^6.4.0",
    "multer": "^2.1.1",
    "mysql2": "^3.9.2",
    "naive-ui": "^2.44.1",
    "pinia": "^2.1.7",
    "sql.js": "^1.14.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "esbuild": "^0.27.4",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "extraResource": [
          "./dist-server",
          "./data",
          "./node_modules/icon-extractor"
        ],
        "icon": "./electron/assets/logo",
        "ignore": [
          "^/dist-electron",
          "^/out",
          "^/src",
          "^/server",
          "^/\\.git",
          "^/\\.npmrc",
          "^/README\\.md",
          "^/debug\\.log",
          "^/build-server\\.js"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip"
        },
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "NexiousTools"
          }
        }
      ]
    }
  }
}
