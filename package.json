{
  "name": "nexious-tools",
  "version": "1.0.3",
  "description": "桌面端工具集 - 网站链接管理、密码管理、代码片段管理",
  "main": "electron/main.cjs",
  "author": "Nexious",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm run server\" \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "build:server": "node build-server.js",
    "build:app": "node node_modules/vite/bin/vite.js build && node build-server.js",
    "server": "node server/index.js",
    "start": "electron .",
    "prepare:package": "node node_modules/vite/bin/vite.js build && node build-server.js && node scripts/prepare-package-stage.cjs",
    "package": "pnpm prepare:package && node scripts/run-electron-builder.cjs --dir",
    "package:exe": "pnpm prepare:package && node scripts/run-electron-builder.cjs --win nsis",
    "package:portable": "pnpm prepare:package && node scripts/run-electron-builder.cjs --win portable",
    "package:all": "pnpm prepare:package && node scripts/run-electron-builder.cjs --win nsis portable"
  },
  "dependencies": {
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@vicons/ionicons5": "^0.13.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^4.18.3",
    "icon-extractor": "^1.0.3",
    "mammoth": "^1.12.0",
    "md-editor-v3": "^6.4.0",
    "multer": "^2.1.1",
    "naive-ui": "^2.44.1",
    "pdf-parse": "^2.4.5",
    "pinia": "^2.1.7",
    "sql.js": "^1.14.1",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.27.4",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  }
}
